{
  "name": "@toopo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "node --import tsx src/bin/generate.ts",
    "db:migrate": "node --env-file=../../apps/api/.env --import tsx src/bin/migrate.ts"
  },
  "dependencies": {
    "@libsql/kysely-libsql": "0.4.1",
    "kysely": "0.29.2",
    "pg": "8.21.0"
  },
  "peerDependencies": {
    "better-auth": "~1.6.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.1",
    "@toopo/tsconfig": "workspace:*",
    "@toopo/vitest-config": "workspace:*",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.6",
    "better-auth": "~1.6.11",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.6",
    "zod": "4.4.3"
  }
}
