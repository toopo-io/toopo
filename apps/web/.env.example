NODE_ENV=development
# Set to debug for deep debugging; default info keeps dev output readable.
LOG_LEVEL=info
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ---- Phase 4: Auth ----
# Public URL where Better Auth is mounted on apps/api. Kept separate from
# NEXT_PUBLIC_API_URL so auth can move to its own subdomain later.
NEXT_PUBLIC_AUTH_URL=http://localhost:4000

# Explicit boolean toggle so the Google button visibility can be controlled
# from the client side (since the actual GOOGLE_CLIENT_ID lives only on the
# server). Set to "true" only when the API also has GOOGLE_CLIENT_ID +
# GOOGLE_CLIENT_SECRET configured.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
