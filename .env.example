# ── Toopo self-host configuration (ADR-0030) ───────────────────────────────
# Copy this file to `.env`, set BETTER_AUTH_SECRET, then `docker compose up
# --build`. Every other value has a working default for a local run. The stack
# is fail-closed: the optional integrations below stay disabled until you fill
# them in — nothing breaks when they are blank. Never commit a filled-in `.env`.

NODE_ENV=production
LOG_LEVEL=info

# ── Public origins ─────────────────────────────────────────────────────────
# The URLs a browser uses to reach the stack. For a remote deploy set these to
# your real URLs (e.g. https://toopo.example.com / https://api.toopo.example.com)
# — and rebuild web, since the NEXT_PUBLIC_* values are baked at build time
# (ADR-0030 §3). The web container reaches the API internally over the compose
# network (INTERNAL_API_URL=http://api:4000, wired in docker-compose.yml).
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000

# Behind a TLS-terminating reverse proxy set TRUST_PROXY=true so the API reads
# the real client IP from X-Forwarded-For — rate limiting tracks per client
# instead of lumping everyone under the proxy's IP. Leave false when clients
# reach the API directly: trusting forwarded headers without a proxy lets a
# client spoof its IP.
TRUST_PROXY=false

# ── Database ───────────────────────────────────────────────────────────────
# Default: SQLite in the `toopo-data` volume — single-host, low-concurrency
# (ADR-0030 §4). For Postgres, run with docker-compose.postgres.yml and either
# leave this unset (the overlay defaults to the bundled db service) or set a
# full postgres:// URL. (ADR-0017)
DATABASE_URL=file:/data/toopo.db

# ── Auth (REQUIRED — the one value you must set) ───────────────────────────
# Generate: openssl rand -base64 32   (min 32 chars; the API refuses to boot
# without it.)
BETTER_AUTH_SECRET=

# ── GitHub App (OPTIONAL — the connect-a-repo flow) ────────────────────────
# Unset ⇒ the stack runs fully; the connect endpoints and webhook fail closed
# (503) and the worker clones public repos only (ADR-0024/0026). Registering the
# App is documented in docs/github-app-connect-setup.md. The private key is the
# base64 encoding of the PEM (ADR-0026 §7).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# ── Email (OPTIONAL) ───────────────────────────────────────────────────────
# Unset ⇒ the API logs email payloads instead of sending them (ADR-0011).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Toopo

# ── Google OAuth (OPTIONAL) ────────────────────────────────────────────────
# Set both to enable Google sign-in, then also set
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true so the web button appears.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Web client toggles (baked into the web image at build time) ────────────
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# ── Postgres overlay credentials (only used with docker-compose.postgres.yml) ─
# POSTGRES_PASSWORD has NO default — set it before using the Postgres overlay or
# the db container refuses to start (fail-visible). It propagates to both the db
# service and the connection URL.
POSTGRES_USER=toopo
POSTGRES_PASSWORD=
POSTGRES_DB=toopo
