NODE_ENV=development
# Set to debug for deep debugging; default info keeps dev output readable.
LOG_LEVEL=info
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ---- Phase 4: Database (Neon Postgres) ----
# Pooled connection string from your Neon project's "Connection details" panel.
# Use the pooled URL (PgBouncer endpoint). The unpooled variant is only needed
# for long-lived transactions; we do not currently use it.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ---- Phase 4: Better Auth ----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL where the API is reachable. Keep separate from CORS_ORIGIN so
# auth can move to its own subdomain (auth.toopo.io) without coupling.
BETTER_AUTH_URL=http://localhost:4000

# ---- Phase 4: Resend (transactional email) ----
# Optional in dev. When RESEND_API_KEY is unset, the API logs email payloads
# via Pino instead of sending. See apps/api/README.md for the dual-mode
# behavior.
RESEND_API_KEY=
# Default sender is Resend's onboarding domain; you can only send to your
# verified Resend account address from it. Replace with a real domain once
# Toopo's sending domain is verified.
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Toopo

# ---- Phase 4: Google OAuth (optional) ----
# Both must be set to enable the Google sign-in button. If either is missing,
# the server does not register the Google provider and the web UI hides the
# button (gated by NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED on the web side).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Phase B: GitHub push webhook (optional) ----
# The shared secret configured on the GitHub App / repository webhook. Used to
# verify X-Hub-Signature-256 (HMAC-SHA256 over the raw body) before any work.
# Optional: when unset, POST /v1/webhooks/github fails closed with 503 and never
# accepts an unsigned request. Must be at least 16 chars when set. See ADR-0024.
GITHUB_WEBHOOK_SECRET=
