{
  "name": "@toopo/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Toopo worker — ingest→persist populate CLI + queue consume mode (clone, content-hash delta, full-replace persist; ADR-0020, ADR-0025)",
  "license": "AGPL-3.0-or-later",
  "bin": {
    "toopo-worker": "./dist/cli/bin.js",
    "toopo-worker-consume": "./dist/consume/bin.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "ingest": "node --import tsx src/cli/bin.ts",
    "consume": "node --import tsx src/consume/bin.ts"
  },
  "dependencies": {
    "@toopo/db": "workspace:*",
    "@toopo/env": "workspace:*",
    "@toopo/github-app": "workspace:*",
    "@toopo/ingest": "workspace:*",
    "@toopo/lang-react": "workspace:*",
    "@toopo/queue": "workspace:*"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.1",
    "@toopo/core": "workspace:*",
    "@toopo/parser": "workspace:*",
    "@toopo/tsconfig": "workspace:*",
    "@toopo/vitest-config": "workspace:*",
    "@types/node": "25.8.0",
    "@vitest/coverage-v8": "4.1.6",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
