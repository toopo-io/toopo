    "@nestjs/platform-fastify": "11.1.21",
    "@nestjs/swagger": "11.4.3",
    "@toopo/api-contracts": "workspace:*",
    "@toopo/db": "workspace:*",
    "@toopo/env": "workspace:*",
    "@toopo/i18n": "workspace:*",
    "better-auth": "~1.6.11",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "i18next": "26.2.0",
    "kysely": "0.29.2",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "5.4.0",
    "pino": "10.3.1",
