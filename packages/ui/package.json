{
  "name": "@toopo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.js",
      "default": "./dist/lib/utils.js"
    },
    "./components/button": {
      "types": "./dist/components/button.d.ts",
      "import": "./dist/components/button.js",
      "default": "./dist/components/button.js"
    },
    "./components/card": {
      "types": "./dist/components/card.d.ts",
      "import": "./dist/components/card.js",
      "default": "./dist/components/card.js"
    },
    "./components/input": {
      "types": "./dist/components/input.d.ts",
      "import": "./dist/components/input.js",
      "default": "./dist/components/input.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@toopo/tailwind-config": "workspace:*",
    "@toopo/tsconfig": "workspace:*",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3"
  }
}
